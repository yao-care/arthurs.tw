---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="找不到頁面" description="這個網址目前找不到內容。">
  <section class="section" style="min-height: 50vh; display: grid; place-items: center;">
    <div class="container prose text-center">
      <h1>找不到這個頁面</h1>
      <p class="lede mx-auto" style="margin-top: 1rem;">你要找的內容可能被移動或還沒建立。</p>
      <p style="margin-top: 1.5rem;"><a href="/" class="btn btn-primary">回首頁</a> <a href="/qa/" class="btn btn-secondary">看常見問題</a></p>
    </div>
  </section>
</BaseLayout>
