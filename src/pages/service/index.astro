---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import { SITE, STEPS } from "../../lib/site";
import { breadcrumbSchema, serviceSchema } from "../../lib/seo";
const schemas = [
  breadcrumbSchema([{ name: "首頁", path: "/" }, { name: "服務方式", path: "/service/" }]),
  serviceSchema(),
];
const services = [
  { title: "6,000 元顧問服務（核心）", desc: "看不懂 AI、沒空管網站？付一次 6,000 元顧問費，我用 AI 幫你把網站建好、交接、帶你上手，讓你也享受 AI 紅利。", href: "/pricing/" },
  { title: "帶你用 AI 聊天更新", desc: "交接時手把手教你，用一般說話的方式請 AI 改網站——新增產品、修改介紹，不必再回頭找廠商。", href: "/how-it-works/" },
  { title: "內容持續成長", desc: "網站會依搜尋資料、來客行為與客戶提問，持續找出內容缺口、產生文章與 QA，人工確認後發布。", href: "/content-lab/" },
];
---
<BaseLayout title="服務方式" description="Arthurs 的核心是 6,000 元一次性顧問服務：看不懂 AI 也沒關係，我用 AI 幫你把網站建好、帶你上手，並讓網站內容持續成長。" schemas={schemas}>
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">首頁</a> ／ 服務方式</p>
      <h1>服務方式</h1>
      <p class="lede">我們做的不是「再放一個不會動的網站」，而是一個能被 AI 持續協助管理、而且完全屬於你的網站。</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {services.map((s) => (
          <a href={s.href} class="card card-link">
            <h3>{s.title}</h3>
            <p class="muted">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="section section-soft">
    <div class="container">
      <span class="eyebrow">三步驟</span>
      <h2 class="section-title">從提供資料到完整交接。</h2>
      <div class="grid grid-3" style="margin-top: 2rem;">
        {STEPS.map((s, i) => (
          <div class="card"><span class="num-badge">{i + 1}</span><h3>{s.title}</h3><p class="muted">{s.desc}</p></div>
        ))}
      </div>
      <p style="margin-top: 1.5rem;"><Cta /></p>
    </div>
  </section>
</BaseLayout>
