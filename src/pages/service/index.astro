---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import { breadcrumbSchema, serviceSchema } from "../../lib/seo";
const schemas = [
  breadcrumbSchema([{ name: "首頁", path: "/" }, { name: "服務方式", path: "/service/" }]),
  serviceSchema(),
];
const services = [
  { title: "6,000 元顧問服務（核心）", desc: "看不懂 AI、沒空管網站？付一次 6,000 元顧問費，我用 AI 幫你把網站建好、交接、帶你上手，讓你也享受 AI 紅利。", href: "/pricing/" },
  { title: "帶你用 AI 聊天更新", desc: "交接時手把手教你，用一般說話的方式請 AI 改網站——新增產品、修改介紹，不必再回頭找廠商。", href: "/how-it-works/" },
  { title: "內容持續成長", desc: "網站會依搜尋資料、來客行為與客戶提問，持續找出內容缺口、產生文章與 QA，人工確認後發布。", href: "/content-lab/" },
];
// 服務方式主軸：這是顧問服務，重點在帶你上手、把資產交到你手上（非建站工序）。
const flow = [
  { title: "先幫你判斷", desc: "看你現在的狀況，老實說這件事對你值不值得做、怎麼做最划算。這段不收錢。" },
  { title: "難的部分我幫你扛", desc: "技術的部分你不用碰，我用 AI 一次幫你做好。做出來就是你的，以後想改，開口講就行。" },
  { title: "帶你上手（重點在這）", desc: "我不是把網站丟給你就走。我會坐下來教你，教到你自己也能改網站、看得懂數據為止。" },
  { title: "之後你自己顧", desc: "網站和帳號都是你的，AI 幫你持續顧。卡住了再回來找我。一次付清，沒有月費。" },
];
---
<BaseLayout title="服務方式" description="Arthurs 的核心是 6,000 元一次性顧問服務：看不懂 AI 也沒關係，我用 AI 幫你把網站建好、帶你上手，並讓網站內容持續成長。" schemas={schemas}>
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">首頁</a> ／ 服務方式</p>
      <h1>服務方式</h1>
      <p class="lede">你缺的不是一個網站，是一個懂 AI、又願意教會你的人。我做的就是這件事。</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <span class="eyebrow">怎麼進行</span>
      <h2 class="section-title">從幫你判斷，到你自己顧得動。</h2>
      <div class="grid grid-2" style="margin-top: 2rem;">
        {flow.map((s, i) => (
          <div class="card"><span class="num-badge">{i + 1}</span><h3>{s.title}</h3><p class="muted">{s.desc}</p></div>
        ))}
      </div>
      <p style="margin-top: 1.5rem;"><Cta /></p>
    </div>
  </section>
  <section class="section section-soft">
    <div class="container">
      <span class="eyebrow">想更深入</span>
      <h2 class="section-title">這幾件事，各有一頁講清楚。</h2>
      <div class="grid grid-3" style="margin-top: 2rem;">
        {services.map((s) => (
          <a href={s.href} class="card card-link">
            <h3>{s.title}</h3>
            <p class="muted">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
