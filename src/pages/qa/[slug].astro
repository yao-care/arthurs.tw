---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { CTA } from "../../lib/site";
import { breadcrumbSchema, faqSchema } from "../../lib/seo";

export async function getStaticPaths() {
  const qa = await getCollection("qa");
  return qa.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const all = await getCollection("qa");
const related = (d.related ?? [])
  .map((slug) => all.find((q) => q.id === slug))
  .filter(Boolean);
const allArticles = await getCollection("articles");
const relatedArticles = (d.relatedArticles ?? [])
  .map((slug) => allArticles.find((a) => a.id === slug))
  .filter(Boolean);

const schemas = [
  breadcrumbSchema([
    { name: "首頁", path: "/" },
    { name: "常見問題", path: "/qa/" },
    { name: d.question, path: `/qa/${entry.id}/` },
  ]),
  faqSchema([{ question: d.question, answer: d.answer }]),
];
---
<BaseLayout title={d.question} description={d.answer} schemas={schemas} ogType="article">
  <section class="page-head">
    <div class="container prose">
      <p class="breadcrumb"><a href="/">首頁</a> ／ <a href="/qa/">常見問題</a> ／ {d.category}</p>
      <h1>{d.question}</h1>
      <p class="lede" style="margin-top: 1rem; color: var(--color-text);">{d.answer}</p>
    </div>
  </section>
  <section class="section">
    <div class="container prose stack">
      <Content />
      {related.length > 0 && (
        <div style="margin-top: 2rem;">
          <h2 style="font-size: var(--text-lg);">相關問題</h2>
          <ul class="footer-links" style="margin-top: 0.75rem;">
            {related.map((r) => <li><a href={`/qa/${r!.id}/`}>{r!.data.question}</a></li>)}
          </ul>
        </div>
      )}
      {relatedArticles.length > 0 && (
        <div style="margin-top: 2rem;">
          <h2 style="font-size: var(--text-lg);">延伸閱讀</h2>
          <ul class="footer-links" style="margin-top: 0.75rem;">
            {relatedArticles.map((a) => <li><a href={`/articles/${a!.id}/`}>{a!.data.title}</a></li>)}
          </ul>
        </div>
      )}
      <p style="margin-top: 2rem;"><a href={CTA.primary.href} class="btn btn-primary">{CTA.primary.label}</a></p>
      {d.updated && <p class="fs-xs muted">最近更新：{d.updated}</p>}
    </div>
  </section>
</BaseLayout>
