---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { QA_CATEGORIES, CTA } from "../../lib/site";
import { breadcrumbSchema, faqSchema } from "../../lib/seo";

const qa = (await getCollection("qa")).sort((a, b) => a.data.order - b.data.order);
const byCat = QA_CATEGORIES.map((cat) => ({
  cat,
  items: qa.filter((q) => q.data.category === cat),
})).filter((g) => g.items.length);

const schemas = [
  breadcrumbSchema([{ name: "首頁", path: "/" }, { name: "常見問題", path: "/qa/" }]),
  faqSchema(qa.map((q) => ({ question: q.data.question, answer: q.data.answer }))),
];
---
<BaseLayout title="常見問題" description="購買 AI 網站前最常見的問題：價格、建置交付、AI 更新、自動內容、Google 搜尋與 AEO/GEO、所有權與安全、顧問服務。" schemas={schemas}>
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">首頁</a> ／ 常見問題</p>
      <h1>常見問題</h1>
      <p class="lede">買之前的疑慮，這裡一次講清楚。誠實交代限制，不保證排名，也不保證 AI 一定推薦。</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      {byCat.map((g) => (
        <div style="margin-bottom: 2.5rem;">
          <h2 style="font-size: var(--text-lg);">{g.cat}</h2>
          <div class="grid grid-2" style="margin-top: 1rem;">
            {g.items.map((q) => (
              <a href={`/qa/${q.id}/`} class="card card-link">
                <h3 style="font-size: var(--text-lg);">{q.data.question}</h3>
                <p class="muted">{q.data.answer.slice(0, 72)}…</p>
              </a>
            ))}
          </div>
        </div>
      ))}
      <p style="margin-top: 1rem;"><a href={CTA.primary.href} class="btn btn-primary">{CTA.primary.label}</a></p>
    </div>
  </section>
</BaseLayout>
