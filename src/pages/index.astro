---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cta from "../components/Cta.astro";
import { getCollection } from "astro:content";
import {
  SITE, PAINS, SOLUTIONS, STEPS, PLAN, OWNERSHIP,
  FEATURED_QA, PILLARS, CASES, POSITIONING,
} from "../lib/site";
import { serviceSchema, faqSchema } from "../lib/seo";

const qa = await getCollection("qa");
const answerOf = (slug: string) => qa.find((q) => q.id === slug)?.data.answer ?? "";
const questionOf = (slug: string) => qa.find((q) => q.id === slug)?.data.question ?? "";
const featured = [...new Set(FEATURED_QA)].filter((slug) => qa.some((q) => q.id === slug));
const faq = faqSchema(
  featured.slice(0, 10).map((slug) => ({ question: questionOf(slug), answer: answerOf(slug) })).filter((x) => x.answer)
);
const caseWall = CASES;
---
<BaseLayout
  title={SITE.name}
  description="網站做完就放著？我用 AI 幫你把舊網站換成自己擁有、能聊天更新的新網站，交接、帶你上手。看不懂沒關係——大家都能享受 AI 紅利。"
  schemas={[serviceSchema(), faq]}
>
  {/* 1. Hero */}
  <section class="hero section">
    <div class="container">
      <h1>看不懂 AI、沒空管網站？<br />我用 AI 幫你把網站建好，帶你上手。</h1>
      <p class="sub">
        把網站交給我，一次做好。之後你自己用聊天更新，不用再找廠商。
      </p>
      <p style="margin: 0 0 2.25rem;"><Cta size="lg" /></p>
      <p class="hero-pillars-lead">同一個網站，會替你做到這五件事：</p>
      <ul class="hero-acronym">
        {PILLARS.map((p) => (
          <li>
            <span class="ha-term">{[...p.label].map((ch, i) => (p.hi.includes(i) ? <b>{ch}</b> : ch))}</span>
            <span class="ha-cn">{p.note}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* 2. 痛點 */}
  <section class="section section-light">
    <div class="container">
      <span class="eyebrow">你不孤單</span>
      <h2 class="section-title">你不是沒有網站，<br />而是網站沒有人持續經營。</h2>
      <div class="grid grid-3" style="margin-top: 2rem;">
        {PAINS.map((p) => (
          <div class="card">
            <h3>{p.title}</h3>
            <p class="muted">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 3. 核心解法 */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">核心解法</span>
      <h2 class="section-title">你需要的，不是再做一個放著不動的網站。</h2>
      <p class="lede">
        我們把你手上的公司資料，整理成一個好維護、你自己也顧得動的新網站。不需要學複雜後台，也不必每次修改都回頭找網站公司。
      </p>
      <div class="grid grid-2" style="margin-top: 2rem;">
        {SOLUTIONS.map((s, i) => (
          <div class="card">
            <span class="num-badge">{i + 1}</span>
            <h3>{s.title}</h3>
            <p class="muted">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 五大定位 —— 品牌名 Arthurs 逐字揭曉（A·R·T·H·U + r·s） */}
  <section class="section section-soft">
    <div class="container">
      <span class="eyebrow">為什麼叫 Arthurs</span>
      <h2 class="section-title">這個名字不是隨便取的，<br />是我們對每個網站的五個承諾。</h2>
      <p class="brand-word" aria-label="Arthurs">
        {PILLARS.map((p) => <span class="brand-word-live">{p.chars}</span>)}<span class="brand-word-tail">s</span>
      </p>
      <p class="lede" style="margin-top: 1rem;">A·R 來自 AI-Ready，最後的 R 是 Rankable，中間 T·H·U 各一個；結尾的 s 是複數。</p>
      <div class="grid grid-3" style="margin-top: 2rem;">
        {PILLARS.map((p) => (
          <div class="card">
            <span class="num-badge">{p.chars}</span>
            <h3>{p.title}</h3>
            <p class="muted">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 7. 三步驟建置流程 */}
  <section class="section section-light">
    <div class="container">
      <span class="eyebrow">三步驟</span>
      <h2 class="section-title">交給我們，三步就上線。</h2>
      <div class="grid grid-3" style="margin-top: 2rem;">
        {STEPS.map((s, i) => (
          <div class="card">
            <span class="num-badge">{i + 1}</span>
            <h3>{s.title}</h3>
            <p class="muted">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 8. 一次性顧問服務方案 */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">一次性顧問服務</span>
      <h2 class="section-title">看不懂沒關係，交給我，一次幫你把 AI 網站做好。</h2>
      <p class="lede">{POSITIONING}</p>
      <div class="grid grid-2" style="margin-top: 2rem;">
        <div class="card">
          <h3>這個顧問服務幫你搞定的事</h3>
          <ul class="check-list" style="margin-top: 0.75rem;">
            {PLAN.includes.map((x) => <li>{x}</li>)}
          </ul>
        </div>
        <div class="card">
          <h3>這些另外自備</h3>
          <ul class="x-list" style="margin-top: 0.75rem;">
            {PLAN.extra.map((x) => <li>{x}</li>)}
          </ul>
          <p class="muted" style="margin-top: 1rem;">
            部分功能（{PLAN.notFits.slice(0, 5).join("、")}等）不包含或需另外評估。
          </p>
        </div>
      </div>
      <p class="btn-row" style="margin-top: 1.5rem;">
        <a href="/pricing/" class="btn btn-secondary">看顧問服務內容</a>
        <a href="/diy/" class="btn btn-secondary">會用 Claude？也可以自己做（DIY）</a>
      </p>
    </div>
  </section>

  {/* 9. 所有權 */}
  <section class="section section-deep">
    <div class="container">
      <span class="eyebrow">網站所有權</span>
      <h2 class="section-title">我們不是把你留在系統裡，而是把網站完整交給你。</h2>
      <div class="grid grid-2" style="margin-top: 1.5rem; gap: 0.75rem;">
        {OWNERSHIP.map((o) => (
          <div class="card" style="background: var(--color-white-a12); border-color: var(--color-white-a20); color: var(--color-text-on-dark); box-shadow: none;">
            <strong style="font-size: var(--text-lg);">{o}</strong>
          </div>
        ))}
      </div>
      <p style="margin-top: 1.5rem; max-width: 46ch;">
        未來即使不再與我們合作，網站仍然可以繼續使用，也可以交給其他人接手。
      </p>
    </div>
  </section>

  {/* 10. 案例牆（真實作品） */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">真實作品</span>
      <h2 class="section-title">我們替不同產業，把資料整理成能上線使用的網站。</h2>
      <div class="grid grid-3" style="margin-top: 2rem;">
        {caseWall.map((c) => (
          <a href={c.deep ?? c.url} class="card card-link" target="_blank" rel="noopener">
            <span class="badge">{c.industry}</span>
            <h3 style="margin-top: 0.6rem;">{c.name}</h3>
            <p class="muted">{c.desc}</p>
          </a>
        ))}
      </div>
      <p style="margin-top: 1.5rem;"><a href="/cases/" class="btn btn-secondary">看全部案例</a></p>
    </div>
  </section>

  {/* 11. 精選 QA */}
  <section class="section section-soft">
    <div class="container">
      <span class="eyebrow">常見問題</span>
      <h2 class="section-title">買之前，你可能想問。</h2>
      <div class="grid grid-2" style="margin-top: 2rem;">
        {featured.slice(0, 12).map((slug) => (
          <a href={`/qa/${slug}/`} class="card card-link">
            <h3 style="font-size: var(--text-lg);">{questionOf(slug)}</h3>
            {answerOf(slug) && <p class="muted">{answerOf(slug).slice(0, 60)}…</p>}
          </a>
        ))}
      </div>
      <p style="margin-top: 1.5rem;"><a href="/qa/" class="btn btn-secondary">看全部常見問題</a></p>
    </div>
  </section>

  {/* 12. 最終 CTA */}
  <section class="section section-deep">
    <div class="container text-center">
      <h2 class="section-title mx-auto">先不用決定要不要重做網站。</h2>
      <p class="lede mx-auto" style="margin-top: 1rem;">
        把現在的網站網址傳給我。我先幫你看看：哪些內容已經過時、Google 是否容易理解、AI 是否能正確認識你的公司，以及是否適合改成 AI 網站。
      </p>
      <p style="margin-top: 1.75rem;">
        <Cta size="lg" />
      </p>
    </div>
  </section>
</BaseLayout>
