---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../lib/site";
import { breadcrumbSchema } from "../../lib/seo";
const schemas = [breadcrumbSchema([{ name: "首頁", path: "/" }, { name: "網站健檢", path: "/website-check/" }])];
const checks = [
  "網站內容是否過時", "產品及服務是否清楚", "Google 是否容易理解網站",
  "AI 是否容易理解公司業務", "網站是否適合持續更新", "是否具備搜尋及流量資料",
  "網站是否掌握在你自己手中", "是否適合這個顧問服務",
];
---
<BaseLayout title="網站健檢" description="把現在的網站網址傳給我，先幫你看看問題在哪裡：內容是否過時、Google 與 AI 是否容易理解、是否適合改成 AI 網站。填表直接送出，或加 LINE 給我。" schemas={schemas}>
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">首頁</a> ／ 網站健檢</p>
      <h1>把現在的網站網址傳給我，我先幫你看看問題在哪裡。</h1>
      <p class="lede">先不用決定要不要重做網站。看完再決定也不遲。</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        <div>
          <h2 style="font-size: var(--text-lg);">我們會先看這幾件事</h2>
          <ul class="check-list" style="margin-top: 1rem;">{checks.map((c) => <li>{c}</li>)}</ul>
          <p class="muted" style="margin-top: 1.5rem;">
            收到你的網站網址後，我們會先從內容、搜尋理解、AI 理解及後續管理方式，看看目前最值得改善的地方。
          </p>
          <div class="card" style="margin-top: 1.5rem;">
            <h3 style="font-size: var(--text-lg); margin-top: 0;">不想填表？直接聯絡也可以</h3>
            <p class="muted" style="margin-top: 0.5rem;">把公司名稱與現在的網站網址傳給我就好。</p>
            <p class="btn-row" style="margin-top: 0.75rem;">
              {SITE.line && <a href={SITE.line} class="btn btn-primary" target="_blank" rel="noopener">加 LINE 傳網址</a>}
              {SITE.email && <a href={`mailto:${SITE.email}`} class="btn btn-secondary">寄 Email</a>}
            </p>
          </div>
        </div>
        <div class="card">
          <form id="check-form">
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
            <div class="field"><label for="company">公司名稱</label><input id="company" name="公司名稱" required /></div>
            <div class="field"><label for="contact">聯絡人</label><input id="contact" name="聯絡人" required /></div>
            <div class="field"><label for="phone">聯絡方式（電話或 Email）</label><input id="phone" name="聯絡方式" required /></div>
            <div class="field"><label for="url">現有網站網址</label><input id="url" name="現有網站網址" placeholder="https://" /></div>
            <div class="field"><label for="industry">公司產業</label><input id="industry" name="公司產業" /></div>
            <div class="field"><label for="problem">最想解決的問題</label><textarea id="problem" name="最想解決的問題"></textarea></div>
            <div class="field">
              <label for="ai">是否已有 ChatGPT 或其他 AI 訂閱</label>
              <select id="ai" name="是否已有AI訂閱"><option value="">請選擇</option><option>已有</option><option>沒有</option><option>不確定</option></select>
            </div>
            <div class="field"><label for="note">其他補充</label><textarea id="note" name="其他補充"></textarea></div>
            <button id="submit-btn" type="submit" class="btn btn-primary" style="width: 100%;">送出網站網址</button>
            <p id="form-note" class="fs-xs muted" style="margin-top: 0.75rem;"></p>
          </form>
        </div>
      </div>
    </div>
  </section>
  <script is:inline define:vars={{ email: SITE.email, line: SITE.line }}>
    const form = document.getElementById("check-form");
    const note = document.getElementById("form-note");
    const btn = document.getElementById("submit-btn");
    const endpoint = "https://formsubmit.co/ajax/" + email;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (form._honey.value) return;
      btn.disabled = true;
      note.textContent = "送出中…";
      const data = Object.fromEntries(new FormData(form));
      data._subject = "網站健檢申請：" + (data["公司名稱"] || "");
      data._template = "table";
      delete data._honey;
      try {
        const r = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify(data),
        });
        if (r.ok) {
          window.location.href = "/website-check/thank-you/";
        } else {
          throw new Error("bad status");
        }
      } catch (err) {
        btn.disabled = false;
        note.textContent = "送出遇到問題，麻煩改用 LINE（" + line + "）或 Email（" + email + "）把網址傳給我，我會盡快回覆。";
      }
    });
  </script>
</BaseLayout>
