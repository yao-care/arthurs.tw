---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import { CASES } from "../../lib/site";
import { breadcrumbSchema } from "../../lib/seo";
const schemas = [breadcrumbSchema([{ name: "首頁", path: "/" }, { name: "網站案例", path: "/cases/" }])];
---
<BaseLayout title="網站案例" description="我們替不同產業把既有資料整理成真正可以上線使用的網站。這裡是已上線的實際作品，包含運動賽事、醫療協會、在地服務、健康工具、教育協會等。" schemas={schemas}>
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">首頁</a> ／ 網站案例</p>
      <h1>網站案例</h1>
      <p class="lede">這些都是已經做出來、上線中的網站。點進去就是實站，不是示意圖。你現在看的這個網站，也是其中之一。</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {CASES.map((c) => (
          <a href={c.deep ?? c.url} class="card card-link" target="_blank" rel="noopener">
            <p style="margin: 0 0 0.5rem;">
              <span class="badge">{c.industry}</span>
              {c.self && <span class="badge badge-plan" style="margin-left: 0.4rem;">本站</span>}
            </p>
            <h3 style="font-size: var(--text-lg);">{c.name}</h3>
            <p class="muted">{c.desc}</p>
            <p class="fs-xs" style="margin: 0;">{c.url.replace(/^https?:\/\//, "").replace(/\/$/, "")} →</p>
          </a>
        ))}
      </div>
      <p class="muted" style="margin-top: 1.5rem;">其他案例持續整理中。每個案例日後會補上：原本的網站問題、我們如何整理架構、如何交接，以及 AI 如何更新。</p>
      <p style="margin-top: 1rem;"><Cta /></p>
    </div>
  </section>
</BaseLayout>
