---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import { FEE_NOTE, PLAN, OWNERSHIP } from "../../lib/site";
import { breadcrumbSchema, serviceSchema } from "../../lib/seo";
const schemas = [
  breadcrumbSchema([{ name: "首頁", path: "/" }, { name: "方案與費用", path: "/pricing/" }]),
  serviceSchema(),
];
---
<BaseLayout title="方案與費用" description="一次性顧問服務：看不懂 AI 也沒關係，我用 AI 幫你把網站建好、交接、帶你上手。含文案圖片整理、自有網域綁定、Google Search Console 與 Analytics 設定與完整交接表。費用洽詢報價，網域與 AI 訂閱另計。" schemas={schemas}>
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">首頁</a> ／ 方案與費用</p>
      <h1>一次性顧問服務，一次帶你上手。</h1>
      <p class="lede">付一筆顧問費，我用 AI 幫你把網站建好、交接、教你之後自己用，讓看不懂的你，也享受得到 AI 紅利。{FEE_NOTE}，先講好再開始，不亂喊價。網域費與你自己訂閱的 AI 另計，沒有其他隱藏費用。</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        <div class="card">
          <h3>這筆顧問費幫你搞定的事</h3>
          <ul class="check-list" style="margin-top: 0.75rem;">{PLAN.includes.map((x) => <li>{x}</li>)}</ul>
        </div>
        <div class="stack" style="display: grid; gap: 1.5rem;">
          <div class="card">
            <h3>你需要提供</h3>
            <ul class="check-list" style="margin-top: 0.75rem;">{PLAN.provide.map((x) => <li>{x}</li>)}</ul>
          </div>
          <div class="card">
            <h3>費用另計</h3>
            <ul class="x-list" style="margin-top: 0.75rem;">{PLAN.extra.map((x) => <li>{x}</li>)}</ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section section-soft">
    <div class="container">
      <div class="grid grid-2">
        <div class="card">
          <h3>適用範圍</h3>
          <ul class="pill-list" style="margin-top: 0.75rem;">{PLAN.fits.map((x) => <li>{x}</li>)}</ul>
        </div>
        <div class="card">
          <h3>不包含或需另外評估</h3>
          <ul class="x-list" style="margin-top: 0.75rem;">{PLAN.notFits.map((x) => <li>{x}</li>)}</ul>
          <p class="fs-xs muted" style="margin-top: 0.75rem;">這類功能通常需要額外系統與維護，會另外評估，不在這個顧問服務範圍內。</p>
        </div>
      </div>
    </div>
  </section>
  <section class="section section-deep">
    <div class="container text-center">
      <h2 class="section-title mx-auto">網站做好後，完整屬於你。</h2>
      <ul class="pill-list" style="justify-content: center; margin-top: 1rem;">
        {OWNERSHIP.map((o) => <li style="background: var(--color-white-a12); border-color: var(--color-white-a20); color: var(--color-text-on-dark);">{o}</li>)}
      </ul>
      <p style="margin-top: 1.75rem;"><Cta size="lg" /></p>
    </div>
  </section>
</BaseLayout>
