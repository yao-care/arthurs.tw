---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import { getCollection } from "astro:content";
import { breadcrumbSchema } from "../../lib/seo";

const articles = (await getCollection("articles")).sort((a, b) => a.data.order - b.data.order);
const cats = [...new Set(articles.map((a) => a.data.category))];
const schemas = [breadcrumbSchema([{ name: "首頁", path: "/" }, { name: "最新文章", path: "/articles/" }])];
---
<BaseLayout title="最新文章" description="根據客戶問題、搜尋資料及網站行為持續產生的內容知識庫：為什麼 Google 找不到公司、網站沒人維護怎麼辦、AI 如何協助更新、網站所有權與維護費。" schemas={schemas}>
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">首頁</a> ／ 最新文章</p>
      <h1>最新文章</h1>
      <p class="lede">這裡不是一般部落格，而是根據客戶問題、搜尋資料及網站行為，持續產生的內容知識庫。</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      {cats.map((cat) => (
        <div style="margin-bottom: 2.5rem;">
          <h2 style="font-size: var(--text-lg);">{cat}</h2>
          <div class="grid grid-2" style="margin-top: 1rem;">
            {articles.filter((a) => a.data.category === cat).map((a) => (
              <a href={`/articles/${a.id}/`} class="card card-link">
                <h3 style="font-size: var(--text-lg);">{a.data.title}</h3>
                <p class="muted">{a.data.summary}</p>
                {a.data.updated && <p class="fs-xs muted">更新：{a.data.updated}</p>}
              </a>
            ))}
          </div>
        </div>
      ))}
      <p style="margin-top: 1rem;"><Cta /></p>
    </div>
  </section>
</BaseLayout>
