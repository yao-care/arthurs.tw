---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { CTA } from "../../lib/site";
import { breadcrumbSchema, articleSchema } from "../../lib/seo";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const path = `/articles/${entry.id}/`;

const meta = [
  ["內容產生原因", d.reason],
  ["資料來源", d.sources],
  ["AI 協助", d.aiHelp],
  ["人工確認", d.humanReview],
].filter(([, v]) => v);

const schemas = [
  breadcrumbSchema([
    { name: "首頁", path: "/" },
    { name: "最新文章", path: "/articles/" },
    { name: d.title, path },
  ]),
  articleSchema({ title: d.title, description: d.summary, path, created: d.created, updated: d.updated }),
];
---
<BaseLayout title={d.title} description={d.summary} schemas={schemas} ogType="article">
  <section class="page-head">
    <div class="container prose">
      <p class="breadcrumb"><a href="/">首頁</a> ／ <a href="/articles/">最新文章</a> ／ {d.category}</p>
      <h1>{d.title}</h1>
      <p class="fs-xs muted" style="margin-top: 0.75rem;">
        {d.created && <>發布：{d.created}　</>}{d.updated && <>最近更新：{d.updated}</>}
      </p>
    </div>
  </section>
  <section class="section">
    <div class="container prose stack">
      <Content />
      {meta.length > 0 && (
        <div class="card" style="margin-top: 2rem;">
          <h2 style="font-size: var(--text-lg); margin-top: 0;">這篇文章怎麼來的</h2>
          <dl class="deflist" style="margin-top: 0.75rem;">
            {meta.map(([k, v]) => (<div><dt>{k}</dt><dd>{v}</dd></div>))}
          </dl>
        </div>
      )}
      <p style="margin-top: 2rem;"><a href={CTA.primary.href} class="btn btn-primary">{CTA.primary.label}</a></p>
    </div>
  </section>
</BaseLayout>
